# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=*

# Model
DEVICE=auto
HF_MODEL_NAME=capcheck/ai-human-generated-image-detection,prithivMLmods/deepfake-detector-model-v1,king1oo1/deepfake-model,Smogy/SMOGY-Ai-images-detector
LOCAL_MODEL_PATH=models/best_model.pt
BACKBONE=efficientnet_b4
IMAGE_SIZE=224
THRESHOLD=0.40
VIDEO_FRAME_THRESHOLD=0.40
VIDEO_OVERALL_THRESHOLD=0.40
VIDEO_FAKE_FRAME_RATIO_THRESHOLD=0.20

# Limits
MAX_FILE_SIZE_MB=200
MAX_BATCH_SIZE=20
MAX_VIDEO_FRAMES=32
RATE_LIMIT_RPM=60
